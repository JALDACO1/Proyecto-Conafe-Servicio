# ============================================================================
# Variables de Entorno - Sistema de Gestión de Archivos Excel CEA
# ============================================================================
# IMPORTANTE: Copia este archivo como ".env.local" y rellena los valores reales
# NUNCA commites el archivo .env.local a Git (contiene credenciales sensibles)
# ============================================================================

# ======== Supabase Configuration ========
# URL de tu proyecto de Supabase
# Formato: https://xxxxxxxxxxxxx.supabase.co
# Obtener en: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your-supabase-url-here

# Anon Key de tu proyecto de Supabase
# Esta key es segura para usar en el frontend (tiene permisos limitados)
# Obtener en: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ======== Configuración de la Aplicación ========
# Nombre de la aplicación (se muestra en UI)
VITE_APP_NAME=Sistema CEA CONAFE

# Tamaño máximo de archivo en MB (por archivo)
# Valor recomendado: 50 (50MB)
VITE_MAX_FILE_SIZE_MB=50

# Tipos de archivo permitidos (separados por coma)
VITE_ALLOWED_FILE_TYPES=.xlsx,.xls

# ======== Configuración de Supabase Storage ========
# Nombres de los buckets de Storage (deben coincidir con los creados en migraciones)
VITE_MASTER_FILES_BUCKET=master-files
VITE_CEA_FILES_BUCKET=cea-files

# ======== Configuración de URLs firmadas ========
# Tiempo de expiración de URLs firmadas en segundos
# Valor recomendado: 900 (15 minutos)
VITE_SIGNED_URL_EXPIRY_SECONDS=900

# ======== Configuración de Realtime ========
# Habilitar/deshabilitar Supabase Realtime
# Valores: true | false
VITE_ENABLE_REALTIME=true

# ======== Modo de desarrollo ========
# No cambiar manualmente - Vite lo configura automáticamente
# DEV=true en desarrollo, false en producción
# Se usa para mostrar logs de debugging
