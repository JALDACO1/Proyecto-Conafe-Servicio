# ============================================================================
# .gitignore - Sistema de Gestión de Archivos Excel CEA
# ============================================================================

# ======== Dependencias ========
node_modules/
.pnp
.pnp.js

# ======== Variables de entorno (CRÍTICO - NUNCA COMMITEAR) ========
.env
.env.local
.env.*.local
.env.production
.env.development

# ======== Build outputs ========
dist/
dist-ssr/
build/
*.local

# ======== Logs ========
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ======== Editor directories y archivos ========
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ======== Testing ========
coverage/
.nyc_output/
playwright-report/
test-results/

# ======== Supabase ========
.supabase/
supabase/.temp/

# ======== Sistema operativo ========
.DS_Store
Thumbs.db

# ======== Archivos temporales ========
*.tmp
*.temp
.cache/
.parcel-cache/

# ======== Otros ========
.vercel
.netlify
.turbo
